# Application
APP_ENV=development
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000

# Database
DATABASE_URL=postgresql+asyncpg://aidm:aidm@localhost:5432/aidm

# Redis
REDIS_URL=redis://localhost:6379/0

# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Model Selection for Different Request Types
# Available Claude models:
#   - claude-sonnet-4-20250514 (latest Sonnet - balanced performance)
#   - claude-3-5-sonnet-20241022 (previous Sonnet)
#   - claude-3-5-haiku-20241022 (fast, lightweight)
#   - claude-3-opus-20240229 (most powerful)

# Model for DM responses during gameplay
MODEL_DM_RESPONSE=claude-sonnet-4-20250514

# Model for generating new scenarios
MODEL_SCENARIO_GENERATION=claude-sonnet-4-20250514

# Model for refining existing scenarios
MODEL_SCENARIO_REFINEMENT=claude-sonnet-4-20250514

# Model for extracting game state from conversations (use faster model)
MODEL_STATE_EXTRACTION=claude-3-5-haiku-20241022

# JWT Authentication
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Apple Sign In
APPLE_CLIENT_ID=

# S3/R2 Storage
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=aidm-audio
S3_REGION=auto

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# Rate Limiting
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_PERIOD=60

# Logging
# LOG_LEVEL: DEBUG, INFO, WARNING, ERROR, CRITICAL
# LOG_FORMAT: console (pretty colors), json (structured)
LOG_LEVEL=INFO
LOG_FORMAT=console
